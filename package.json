{
  "name": "@yuges/parser-ts",
  "description": "A TS Library for parser code",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Georgy",
    "nickname": "goshasafonov",
    "email": "goshasafonov@yandex.ru",
    "github": "https://github.com/goshasafonov"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuges-code/parser-ts.git"
  },
  "main": "./dist/parser-ts.umd.cjs",
  "module": "./dist/parser-ts.js",
  "types": "./dist/types/index.d.ts",
  "files": [
