    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "node ./scripts/test.js"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "dependencies": {
    "@types/node": "^26.1.0",
    "vite-plugin-dts": "^5.0.3"
  }
}
